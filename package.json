{
  "name": "dowin",
  "version": "1.12.0",
  "private": true,
  "packageManager": "yarn@4.10.0",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "prettier": "npx prettier --write .",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "test": "vitest",
    "test:frontend": "vitest --run src/app/_components 'src/app/[locale]' src/components src/context src/hooks src/lib/client",
    "test:backend": "vitest --run src/app/api src/domain src/lib/server",
    "test:ui": "vitest --ui",
    "test:storybook": "vitest --config vitest.storybook.config.mts",
    "test:checkin": "node --env-file=.env scripts/test-team-checkin.mjs",
    "test:checkin:clear": "bash scripts/clear-team-checkins.sh",
    "test:billing": "node --env-file=.env scripts/test-billing-revocation.mjs",
    "gen:api": "orval",
    "mig:local": "npx drizzle-kit generate && npx wrangler d1 migrations apply wig-db --local",
    "mig:remote": "drizzle-kit generate && wrangler d1 migrations apply wig-db --remote",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "perf:api": "node scripts/perf-api.mjs",
    "perf:log:tail": "tail -f tmp/perf-api.ndjson",
    "db:studio": "npx drizzle-kit studio",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.33",
    "@opennextjs/cloudflare": "^1.17.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.21",
    "@webview-bridge/web": "^1.7.9",
    "ai": "^6.0.104",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.9.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-intl": "^4.9.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-joyride": "^3.0.0",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/eslintrc": "^3",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/nextjs-vite": "^10.2.19",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/canvas-confetti": "^1",
    "@types/jsdom": "^28",
    "@types/node": "^25.3.2",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "eslint-plugin-storybook": "^10.2.19",
    "husky": "^9.0.0",
    "jsdom": "^28.1.0",
    "orval": "^8.5.3",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "storybook": "^10.2.19",
    "tailwindcss": "^4",
    "typescript": "^5.7.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.0",
    "wrangler": "^4.69.0"
  }
}
